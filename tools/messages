if [ "$#" -eq 0 ]
then
    echo "Usage: $0 NODE"
    exit 1
fi

sqlite3 a.db <<EOM
.mode json 
SELECT node, 
lz_entities.id AS entity_id,
title,
-- GROUP_CONCAT(content, "::")
json_group_array(content) as content
FROM lz_connections
INNER JOIN lz_entries ON lz_entries.id = lz_connections.id
INNER JOIN lz_blocks ON lz_blocks.parent = lz_entries.id
INNER JOIN lz_entities ON lz_connections.id = lz_entities.rowid
WHERE
node LIKE '$1'
GROUP BY entity_id
ORDER BY entity_id, lz_blocks.id
;
EOM
