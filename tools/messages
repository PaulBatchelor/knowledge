if [ "$#" -eq 0 ]
then
    echo "Usage: $0 NODE"
    exit 1
fi

# reworked JSON output, bug is still there, but 'content'
# now is json
sqlite3 a.db <<EOM
WITH results AS
(SELECT
json_object(
'node', node, 
'entity_id', lz_entities.id,
'title', title,
'content', json_group_array(content),
'block_ids', json_group_array(lz_blocks.id)
) as json_result
FROM lz_connections
INNER JOIN lz_entries ON lz_entries.id = lz_connections.id
LEFT JOIN lz_blocks ON lz_blocks.parent = lz_connections.id
INNER JOIN lz_entities ON lz_connections.id = lz_entities.rowid
WHERE
node LIKE '$1'
GROUP BY lz_entities.id, node
ORDER BY lz_entities.id, lz_blocks.id)
SELECT json_group_array(json(json_result)) FROM results
;
EOM
