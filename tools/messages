if [ "$#" -eq 0 ]
then
    echo "Usage: $0 NODE"
    exit 1
fi

sqlite3 a.db <<EOM
WITH results AS
(SELECT
json_object(
'node', node, 
'entity_id', lz_entities.id,
'title', title,
'content', json_group_array(DISTINCT content),
'block_ids', json_group_array(DISTINCT lz_blocks.id)
) as json_result
FROM lz_connections
INNER JOIN lz_entries ON lz_entries.id = lz_connections.id
LEFT JOIN lz_blocks ON lz_blocks.parent = lz_connections.id
INNER JOIN lz_entities ON lz_connections.id = lz_entities.rowid
WHERE
node LIKE '$1'
GROUP BY node, lz_entities.id
ORDER BY lz_entities.id, lz_blocks.id),

nodes AS (SELECT
json_object(
'name', name,
'content', json(ifnull(lines, '[]'))
)
as obj
FROM dz_nodes
LEFT JOIN dz_lines on dz_lines.node = dz_nodes.id
WHERE name LIKE '$1'
),

aggregated AS (
  SELECT
    (SELECT json_group_array(json(json_result)) FROM results) AS logs,
    (SELECT json_group_array(json(obj)) FROM nodes) AS nodes
)
SELECT json_object(
  'logs', json(logs),
  'nodes', json(nodes)
)
FROM aggregated
;
EOM
